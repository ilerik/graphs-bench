{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/lean4-skills/plugins/lean4/skills"]
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp"],
      "enabled": true,
      "env": {
        "PATH": "/home/user/.local/bin:/home/user/.elan/bin:/usr/local/bin:/usr/bin:/bin",
        "LEAN_PROJECT_PATH": "/home/user/nuconstruct/graphs-bench/formal/lean"
      }
    }
  }
}
