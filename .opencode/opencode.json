{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/lean4-skills/plugins/lean4/skills"]
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "export PATH=/home/user/.local/bin:/home/user/.elan/bin:$PATH; exec uvx lean-lsp-mcp"
      ],
      "enabled": true,
      "env": {
        "LEAN_PROJECT_PATH": "/home/user/nuconstruct/graphs-bench/formal/lean"
      }
    }
  }
}
